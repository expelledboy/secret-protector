# Project-level overrides for secret-protector
# Files: block_globs/block_regex block; allow_globs/allow_regex permit (like .gitignore)
env:
  block_exact:
    - STRIPE_SECRET_KEY
files:
  block_globs:
    - '**/*production*.tfvars'
    - '**/*.kubeconfig'
  allow_globs:
    - 'config/env.example.yml'
